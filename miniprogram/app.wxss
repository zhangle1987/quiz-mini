/**app.wxss**/
:root {
  --ant-primary: #1677ff;
  --ant-primary-hover: #4096ff;
  --ant-text: #262626;
  --ant-text-secondary: #595959;
  --ant-text-tertiary: #8c8c8c;
  --ant-border: #d9d9d9;
  --ant-border-light: #f0f0f0;
  --ant-bg: #f5f7fa;
  --ant-bg-elevated: #ffffff;
  --ant-bg-soft: #fafafa;
  --ant-success-bg: #f6ffed;
  --ant-success-text: #52c41a;
  --ant-error-bg: #fff2f0;
  --ant-error-text: #ff4d4f;
  --ant-shadow: 0 10rpx 28rpx rgba(5, 26, 62, 0.06);
  --ant-radius-lg: 24rpx;
  --ant-radius-md: 16rpx;
  --button-color: #595959;
  --button-background-color: #ffffff;
  --button-border-color: #d9d9d9;
  --button-primary-color: #ffffff;
  --button-primary-background-color: #1677ff;
  --button-primary-border-color: #1677ff;
  --button-default-aide-color: #595959;
  --button-default-aide-background-color: #ffffff;
  --button-default-aide-border-color: #d9d9d9;
  --radio-text-color: #262626;
  --radio-border-color: #d9d9d9;
  --radio-background-color: #1677ff;
  --radio-disabled-background: #f5f5f5;
  --ant-card-bg: #ffffff;
  --ant-card-header-title-color: #262626;
  --ant-card-divider-color: #f0f0f0;
  --list-header-color: #8c8c8c;
  --list-background-color: #ffffff;
  --list-content-color: #262626;
  --list-extra-brief-color: #8c8c8c;
  --list-item-text-color: #d9d9d9;
  --list-item-border-color: #f0f0f0;
  --tag-primary-color: #1677ff;
  --tag-primary-light-color: #e6f4ff;
  --tag-primary-color-faded: rgba(22, 119, 255, 0.2);
  --tag-warning-color: #faad14;
  --tag-warning-light-color: #fffbe6;
  --tag-warning-color-faded: rgba(250, 173, 20, 0.2);
  --tag-success-color: #52c41a;
  --tag-success-light-color: #f6ffed;
  --tag-success-color-faded: rgba(82, 196, 26, 0.2);
  --tag-danger-color: #ff4d4f;
  --tag-danger-light-color: #fff2f0;
  --tag-danger-color-faded: rgba(255, 77, 79, 0.2);
  --progress-trail-color: #f0f0f0;
  --progress-stroke-color: #1677ff;
  --progress-success-color: #52c41a;
  --progress-exception-color: #ff4d4f;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

page {
  background: var(--ant-bg);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  color: var(--ant-text);
}

.ui-card {
  overflow: hidden;
  border-radius: 24rpx;
  border: 1rpx solid var(--ant-border-light);
  background: var(--ant-bg-elevated);
  box-shadow: var(--ant-shadow);
}

.ui-card__head {
  padding: 24rpx 24rpx 0;
}

.ui-card__title {
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  color: var(--ant-text);
}

.ui-card__body {
  padding: 24rpx;
}

.ui-card__body--tight {
  padding-top: 0;
}

.ui-card__body--flush {
  padding: 0;
}

.ui-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 600;
}

.ui-tag--light {
  background: #f5f5f5;
  color: #595959;
}

.ui-tag--primary-light {
  background: #e6f4ff;
  color: #1677ff;
}

.ui-tag--success-light {
  background: #f6ffed;
  color: #389e0d;
}

.ui-tag--danger-light {
  background: #fff2f0;
  color: #cf1322;
}

.ui-progress {
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: var(--progress-trail-color);
}

.ui-progress__bar {
  height: 100%;
  border-radius: inherit;
  background: var(--progress-stroke-color);
  transition: width 0.25s ease;
}

button.ui-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 600;
}

button.ui-button::after {
  border: 0;
}

button.ui-button.ui-button--primary {
  color: #ffffff;
  background: #1677ff;
  box-shadow: 0 10rpx 20rpx rgba(22, 119, 255, 0.16);
}

button.ui-button.ui-button--default {
  color: #434343;
  background: #ffffff;
  box-shadow: inset 0 0 0 2rpx #d9d9d9;
}

button.ui-button.ui-button--small {
  width: auto;
  min-width: 132rpx;
  height: 68rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

button.ui-button.ui-button--hover {
  filter: brightness(0.96);
}

button.ui-button[disabled] {
  opacity: 0.45;
  color: #bfbfbf;
  background: #f5f5f5;
  box-shadow: none;
}

page {
  background: linear-gradient(180deg, #f7f9fc 0%, #f3f6fb 100%);
}

.page {
  padding: 24rpx 24rpx 156rpx;
}

.result-overview {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.paper-title {
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ant-text-secondary);
}

.score-panel {
  padding: 30rpx 24rpx 26rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e9edf2;
  background: linear-gradient(180deg, #fcfdff 0%, #f8fafc 100%);
  text-align: center;
}

.score-panel__caption {
  font-size: 24rpx;
  color: var(--ant-text-tertiary);
}

.score {
  margin-top: 14rpx;
  font-size: 92rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
}

.score-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  text-align: center;
  color: var(--ant-text-tertiary);
}

.summary-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.summary-item {
  flex: 1;
  padding: 22rpx 14rpx;
  border-radius: 16rpx;
  background: #fbfcfe;
  border: 1rpx solid #edf1f5;
}

.summary-item__label {
  font-size: 22rpx;
  color: var(--ant-text-tertiary);
  text-align: center;
}

.summary-item__value {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 600;
  color: var(--ant-text);
  text-align: center;
}

.card-gap {
  height: 16rpx;
}

.broker-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0 4rpx;
}

.broker-card--framed {
  padding: 22rpx 20rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid #edf1f5;
  background: #fbfcfe;
}

.broker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ant-text);
}

.broker-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
  color: var(--ant-text-secondary);
}

.broker-qr {
  width: 360rpx;
  height: 360rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e8edf3;
}

.broker-empty {
  margin-top: 20rpx;
  padding: 24rpx;
  width: 100%;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx dashed #d7dfe7;
  text-align: center;
  color: var(--ant-text-tertiary);
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-block {
  padding: 22rpx 22rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #edf1f5;
  background: #ffffff;
}

.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.result-head__main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-number {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ant-text);
}

.result-reference {
  display: inline-flex;
  width: fit-content;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #eaedf1;
  background: #f8fafc;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--ant-text-tertiary);
}

.result-state {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9e1ea;
  background: #fafbfd;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #475569;
}

.result-state--correct {
  border-color: #d9f0c7;
  background: #f6ffed;
  color: #389e0d;
}

.result-state--wrong {
  border-color: #ffd8bf;
  background: #fff7e6;
  color: #d46b08;
}

.result-stem,
.result-explanation {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ant-text-secondary);
}

.result-answer-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.result-answer-card {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #edf1f5;
  background: #fbfcfe;
}

.result-answer-card__label {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--ant-text-tertiary);
}

.result-answer-card__value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
  color: var(--ant-text);
}

.result-explanation {
  padding: 18rpx 20rpx 20rpx;
  border-radius: 18rpx;
  background: #fbfcfe;
  border: 1rpx solid #edf1f5;
}

.result-explanation__title {
  margin-bottom: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ant-text);
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--ant-border-light);
  box-shadow: 0 -8rpx 24rpx rgba(5, 26, 62, 0.05);
}

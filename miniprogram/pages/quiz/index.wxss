page {
  background: linear-gradient(180deg, #f7f9fc 0%, #f3f6fb 100%);
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 24rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
}

.card-gap {
  height: 16rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quiz-summary {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--ant-text-secondary);
}

.timer-tag--urgent {
  background: #fff2f0;
  color: #cf1322;
}

.progress-wrap {
  margin-top: 18rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #edf1f5;
  background: #fafbfd;
}

.progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-title {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--ant-text-secondary);
}

.progress-value {
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
  color: #1677ff;
}

.progress-track {
  position: relative;
  height: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  border: 1rpx solid #dfe7f0;
  background: linear-gradient(180deg, #eef3f8 0%, #e7edf5 100%);
}

.progress-fill {
  position: relative;
  height: 100%;
  min-width: 24rpx;
  border-radius: inherit;
  background: linear-gradient(90deg, #7ab8ff 0%, #1677ff 100%);
  transition: width 0.25s ease;
}

.progress-fill__glow {
  position: absolute;
  top: 2rpx;
  right: 8rpx;
  width: 56rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  filter: blur(2rpx);
}

.progress-caption {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.progress-caption__text {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--ant-text-tertiary);
}

.question-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.question-number {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ant-text);
}

.question-stem {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #edf1f5;
  background: #fafbfd;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--ant-text);
}

.options-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.quiz-option {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e7ebf0;
  background: #ffffff;
  transition: all 0.2s ease;
}

.quiz-option--press {
  border-color: #d6dde5;
  background: #f8fafc;
}

.quiz-option--active {
  border-color: #8bb9f3;
  background: linear-gradient(180deg, #f9fcff 0%, #f4f9ff 100%);
  box-shadow: 0 10rpx 24rpx rgba(22, 119, 255, 0.09);
}

.quiz-option__mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-top: 2rpx;
  border-radius: 12rpx;
  border: 1rpx solid #d8e0e8;
  background: #f8fafc;
  flex-shrink: 0;
}

.quiz-option__mark--active {
  border-color: #91c3ff;
  background: #1677ff;
  box-shadow: 0 6rpx 14rpx rgba(22, 119, 255, 0.18);
}

.quiz-option__mark-check {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.quiz-option__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.quiz-option__line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.quiz-option__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 44rpx;
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  border: 1rpx solid #dde4ec;
  background: #f8fafc;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #5b6572;
}

.quiz-option__label {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ant-text);
  word-break: break-word;
}

.quiz-option--active .quiz-option__badge {
  border-color: #b7d6ff;
  background: #edf5ff;
  color: #0958d9;
}

.quiz-option--active .quiz-option__label {
  color: #1f3d63;
}

.footer-bar {
  margin-top: auto;
  padding-top: 28rpx;
}

.action-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding-left: 60rpx;
  padding-right: 60rpx;
}

.submit-row {
  margin-top: 60rpx;
}

.quiz-nav-button {
  width: 260rpx !important;
}

.loading {
  padding: 120rpx 32rpx;
  text-align: center;
  color: var(--ant-text-tertiary);
}

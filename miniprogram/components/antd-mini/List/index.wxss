.ant-list-radius {
  margin: 0;
}
.ant-list-radius .ant-list-body {
  border-radius: 24rpx;
}
.ant-list-radius .ant-list-header,
.ant-list-radius .ant-list-footer {
  padding: 16rpx 0;
}
.ant-list-header,
.ant-list-footer {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  line-height: 1.4;
  font-size: 30rpx;
  color: var(--list-header-color, #999999);
}
.ant-list-header:empty,
.ant-list-footer:empty {
  display: none;
}
.ant-list-body {
  position: relative;
  overflow: hidden;
  background-color: var(--list-background-color, #ffffff);
  border: 1rpx solid var(--list-item-border-color, #e5e5e5);
  box-shadow: var(--ant-shadow, 0 6rpx 18rpx rgba(0, 0, 0, 0.06));
}
.ant-list-body > .ant-list-item:last-child .ant-list-item-line::after {
  display: none;
}
